generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Monthly Alibaba order cycle
model Batch {
  id           String   @id @default(cuid())
  name         String // e.g. "August 2026 Batch"
  cutoffDate   DateTime // last day to pre-order into this batch
  pickupStart  DateTime // estimated pickup window
  pickupEnd    DateTime
  status       BatchStatus @default(OPEN)
  orders       Order[]
  // Landed-cost tracking for the supplier order behind this batch.
  freightCents   Int      @default(0) // shipping/freight from supplier
  tariffCents    Int      @default(0) // import tariffs/duties
  otherCostCents Int      @default(0) // brokerage, logo tooling, wire fees, etc.
  costNotes      String?
  unitCosts      BatchUnitCost[] // per-product cost overrides for this order
  expenses       Expense[] // ledger expenses attributed to this batch
  stockLines     BatchStockLine[] // inventory restock lines riding on this supplier order
  createdAt    DateTime @default(now())
}

// Inventory restock riding on a batch's supplier order: "add N units of this
// IN_STOCK SKU to the factory order". Included in the supplier export next to
// pre-order lines. When the batch is marked ARRIVED, each unreceived line
// increments Product.inStock once and flips `received` (so re-toggling the
// status can't double-count).
model BatchStockLine {
  id         String   @id @default(cuid())
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  qty        Int
  received   Boolean  @default(false) // inStock already incremented for this line
  createdAt  DateTime @default(now())

  @@unique([batchId, productId])
}

// Per-batch override of a product's unit cost — supplier quotes drift
// between orders. Falls back to Product.costCents when absent.
model BatchUnitCost {
  id            String  @id @default(cuid())
  batchId       String
  batch         Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  productId     String
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitCostCents Int

  @@unique([batchId, productId])
}

// General-ledger expense line (the "everything else" of the books:
// packaging, marketing, Clover fees, gas, tools...). Optionally tied to a
// batch so landed cost per batch stays complete. Category is free text
// validated against EXPENSE_CATEGORIES in the API layer.
model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  category    String // SHIPPING | TARIFFS | SUPPLIES | FEES | MARKETING | EQUIPMENT | OTHER
  description String
  amountCents Int
  batchId     String?
  batch       Batch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

enum BatchStatus {
  OPEN      // taking pre-orders
  ORDERED   // placed with supplier
  ARRIVED   // ready for pickup
  CLOSED
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  category    String   // was `enum Category`; now validated in the API layer against Category.key so admin can add new categories with no migration
  sizingTier  String?  // SENIOR | INT | JR | YTH | null (goalie/minis have none); validated against SizingTier.key
  specs       String[] @default([]) // admin-editable bullet specs, shown on product detail
  badge       String?  // e.g. "Best Seller" — admin-editable, was code-only
  configurable Boolean @default(false) // true = build the flex/curve/hand/color/length matrix from OptionValue at render time, even if this slug isn't in the static lib/catalog.ts fixture
  type        ProductType @default(PREORDER) // PREORDER = configurable; IN_STOCK = fixed SKU
  priceCents  Int
  costCents   Int      @default(0) // default supplier unit cost; BatchUnitCost overrides per order
  imageUrl    String?
  clubName    String? // for club-customized mini sticks
  inStock     Int      @default(0) // on-hand inventory (IN_STOCK only)
  preorder    Boolean  @default(true) // legacy flag; kept in sync with type. Prefer `type`.
  active      Boolean  @default(true)
  comingSoon  Boolean  @default(false) // shown on the storefront with a "Coming Soon" badge, not buyable (no detail page / cart)
  // Locked build for IN_STOCK SKUs (display only; no customization at checkout).
  fixedFlex   Int?
  fixedCurve  String?
  fixedHand   String?
  fixedColor  String?
  fixedLength String?
  orderItems  OrderItem[]
  batchUnitCosts BatchUnitCost[]
  batchStockLines BatchStockLine[] // restock lines on supplier orders
  productOptions ProductOption[] // per-stick option overrides (Phase 2)
  createdAt   DateTime @default(now())
}

// Two catalogs: built-to-order (configurable) vs on-the-shelf (fixed SKU).
// Kept as a real enum on purpose — it's a structural fork that checkout/cart
// branch on, not a catalog value admin should be adding more of.
enum ProductType {
  PREORDER
  IN_STOCK
}

// Admin-editable product category catalog. Replaces the old `enum Category`
// (FULL_STICK/GOALIE/MINI_CLUB/MINI_FUN are now seeded rows, not enum members)
// so a new category can be added from /admin with no schema migration.
model Category {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "FULL_STICK" — stored on Product.category
  label     String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Marketing email contact + unsubscribe state, keyed by email. A row is
// created (with a stable unsubscribe token) the first time we see an email at
// checkout or a broadcast. `unsubscribed` gates ALL marketing sends. Kept
// separate from Order so unsubscribe survives across orders and guests.
model EmailContact {
  id           String   @id @default(cuid())
  email        String   @unique
  unsubscribed Boolean  @default(false)
  unsubToken   String   @unique @default(cuid()) // used in the unsubscribe link
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Admin-editable club catalog. Drives the "choose your club" picker on the
// custom club mini (customer preorder) and the club field in the admin
// in-stock SKU builder. `active` = "ready" — admin can select any club, but
// customers only see active ones (matches the old per-club "coming soon").
model Club {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(false) // ready — shown to customers
  imageUrl  String?  // club design image — data URL (uploaded) or http URL; shown on the mini picker
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Admin-editable sizing tier catalog (Senior/Int/Jr/Youth). Scopes FLEX and
// LENGTH OptionValue rows and Product.sizingTier. Note: the dedicated
// marketing pages at /sticks/{tier} are still literal Next.js routes (one
// folder per tier) — adding a brand-new tier here makes it a valid scope for
// options/products immediately, but a new landing page route is still a
// small code change. Existing tiers (senior/intermediate/junior/youth) need
// no code changes to relabel, hide, or reorder.
model SizingTier {
  id        String   @id @default(cuid())
  key       String   @unique // "SENIOR" | "INT" | "JR" | "YTH"
  label     String
  tag       String   @default("") // short marketing blurb (was hardcoded in lib/sizeTiers.ts)
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Admin-editable attribute type catalog. Replaces the old `enum OptionKind`
// (FLEX/CURVE/HAND/COLOR/LENGTH/PADDLE are now seeded rows) so a brand-new
// attribute (e.g. "GRIP") can be added from /admin with no migration — it
// immediately becomes selectable in the Pre-Order Options editor.
model AttributeKind {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "FLEX" — stored on OptionValue.kind
  label     String
  unit      String   @default("") // e.g. `"` for length, shown after the value
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Admin-editable option catalog for the pre-order configurator.
// Seeded with defaults; new values can be added from /admin.
// `sizing` scopes tier-specific values (e.g. flex sets, lengths) to
// SENIOR/INT/JR/YTH; "ALL" = applies to all. `category` scopes to
// FULL_STICK/GOALIE; "ALL" = all. (Sentinel string, not NULL, so the
// compound unique index dedupes correctly on Postgres.)
model OptionValue {
  id            String     @id @default(cuid())
  kind          String     // was `enum OptionKind`; now validated against AttributeKind.key
  value         String // canonical stored value, e.g. "P92", "85", "Right", "Black", "57\""
  label         String? // display override; falls back to value
  sizing        String     @default("ALL") // SENIOR | INT | JR | YTH | ALL
  category      String     @default("ALL") // FULL_STICK | GOALIE | ALL
  upchargeCents Int        @default(0)
  isDefault     Boolean    @default(false) // pre-selected in configurator
  sortOrder     Int        @default(0)
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  productOptions ProductOption[]

  @@unique([kind, value, sizing, category])
}

// Phase 2 per-product option override. Normally a configurable product
// inherits its option set from the tier/category-scoped OptionValue rows
// (see lib/options.ts). When a specific stick must differ (e.g. a shorter
// curve list), admin pins the exact OptionValues here. Resolution rule: if a
// product has ANY ProductOption rows for a given attribute kind, those rows
// REPLACE the scoped set for that kind only; all other kinds still inherit.
model ProductOption {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValueId String
  optionValue   OptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([productId, optionValueId])
}

model Order {
  id            String   @id @default(cuid())
  email         String
  name          String
  phone         String?
  clerkUserId   String? // set when logged in; guest checkout leaves null
  batchId       String? // null = fulfilled from stock
  batch         Batch?   @relation(fields: [batchId], references: [id])
  items         OrderItem[]
  subtotalCents Int
  discountCents Int      @default(0) // club bulk "donation back" discount already netted into subtotalCents
  couponId      String? // applied promo code, if any
  coupon        Coupon?  @relation(fields: [couponId], references: [id])
  couponCode    String? // denormalized code for display/history
  couponDiscountCents Int @default(0) // coupon savings already netted into subtotalCents
  marketingOptIn Boolean @default(false) // explicit consent to marketing email, captured at checkout
  status        OrderStatus @default(PENDING_PAYMENT)
  cloverCheckoutId String? @unique
  cloverPaymentId  String?
  pickedUpAt    DateTime?
  warrantyClaims WarrantyClaim[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Promo / discount codes managed from /admin and applied at checkout.
model Coupon {
  id               String   @id @default(cuid())
  code             String   @unique // stored uppercase
  kind             CouponKind
  value            Int // PERCENT: 1-100 ; FIXED: cents off ; TIERED_PERCENT: unused (see `tiers`)
  // TIERED_PERCENT only: quantity breakpoints, e.g.
  // [{"minQty":2,"percent":10},{"minQty":5,"percent":20},{"minQty":10,"percent":25}]
  // — the highest tier whose minQty <= cart quantity applies.
  tiers            Json?
  active           Boolean  @default(true)
  minSubtotalCents Int      @default(0) // order must reach this (pre-coupon) to qualify
  maxRedemptions   Int? // null = unlimited
  timesRedeemed    Int      @default(0)
  startsAt         DateTime? // null = active immediately
  expiresAt        DateTime?
  orders           Order[]
  createdAt        DateTime @default(now())
}

enum CouponKind {
  PERCENT
  FIXED
  TIERED_PERCENT // quantity-based: e.g. buy 2-4 get 10%, 5-9 get 20%, 10+ get 25%
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  READY_FOR_PICKUP
  PICKED_UP
  CANCELLED
  REFUNDED
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  priceCents Int // unit price at purchase time (incl. option upcharges)
  options    Json? // { flex, curve, hand, color, customName }
}

model ClubInquiry {
  id        String   @id @default(cuid())
  orgType   String   @default("CLUB") // CLUB | SCHOOL | TEAM | OTHER — who's asking for a custom stick
  interest  String   @default("MINIS") // MINIS (custom-logo minis) | FULL_STICKS (team bulk, standard builds, no logo) | BOTH
  clubName  String
  contact   String
  email     String
  message   String
  createdAt DateTime @default(now())
}

// General "Contact Us" message from the storefront contact page.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

// Broken-stick warranty claim. Window: 30 days from purchase.
// Must be filed online with photos + order reference.
model WarrantyClaim {
  id          String   @id @default(cuid())
  orderId     String // verified against Order.id at submit time
  order       Order    @relation(fields: [orderId], references: [id])
  email       String // must match the order's email
  name        String
  phone       String?
  productName String // which stick broke (free text / from order items)
  description String // what went wrong
  photos      WarrantyPhoto[]
  status      WarrantyStatus @default(SUBMITTED)
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Base64-encoded image stored inline. Kept in its own table so the
// (large) blobs don't get pulled on every claim list query.
model WarrantyPhoto {
  id        String   @id @default(cuid())
  claimId   String
  claim     WarrantyClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  mimeType  String
  dataBase64 String // raw base64 (no data: prefix)
  createdAt DateTime @default(now())
}

enum WarrantyStatus {
  SUBMITTED
  APPROVED
  DENIED
  REPLACED
  REFUNDED
}
