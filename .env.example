# --- Railway Postgres ---
# Railway dashboard -> Postgres -> Connect -> Postgres Connection URL
DATABASE_URL="postgresql://user:pass@host:5432/railway"

# --- Clover Hosted Checkout ---
# Sandbox: https://sandbox.dev.clover.com  |  Production: https://www.clover.com
# Merchant ID: Clover dashboard -> Setup -> Merchants
CLOVER_MERCHANT_ID=""
# API token with "Online payments / Checkout" permission (Setup -> API Tokens)
CLOVER_API_TOKEN=""
# apisandbox.dev.clover.com for testing, api.clover.com for production
CLOVER_API_BASE="https://apisandbox.dev.clover.com"
# Signing Secret from Clover dashboard -> Settings -> Ecommerce -> Hosted
# Checkout -> Webhook section. REQUIRED in production — without it the
# webhook rejects all payment-confirmation events (see app/api/webhooks/clover).
CLOVER_WEBHOOK_SECRET=""

# --- Clerk (optional — site works without it; guest checkout always allowed) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# --- Admin dashboard (/admin) ---
# Shared password for the single-owner admin gate. Use a long random value.
ADMIN_PASSWORD=""
# Optional: separate secret used to sign admin session tokens. Falls back to
# a hash of ADMIN_PASSWORD if unset — set this explicitly to rotate sessions
# independently of the login password.
ADMIN_SESSION_SECRET=""

# --- Low-stock alert email (optional — Resend) ---
RESEND_API_KEY=""
ALERT_EMAIL=""
EMAIL_FROM="STL Hockey Sticks <onboarding@resend.dev>"

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://stlhockeysticks.com"
# Pickup location shown at checkout + footer
NEXT_PUBLIC_PICKUP_ADDRESS="St. Louis, MO (exact address emailed with pickup confirmation)"
